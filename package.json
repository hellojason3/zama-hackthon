{
  "name": "privyields",
  "version": "0.1.0",
  "private": true,
  "description": "Confidential Qualified Yield Market built with Zama.",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "clean": "rimraf ./artifacts ./cache ./coverage ./types ./.next ./dist",
    "compile": "cross-env TS_NODE_TRANSPILE_ONLY=true hardhat compile",
    "test": "hardhat test",
    "typecheck": "tsc --noEmit",
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "deploy:localhost": "hardhat deploy --network localhost",
    "deploy:sepolia": "hardhat deploy --network sepolia",
    "deploy:sepolia:production": "bash scripts/deploy-sepolia-production.sh",
    "deploy:server": "bash scripts/deploy-zama-hackathon.sh",
    "write-env:localhost": "node scripts/write-local-env.cjs",
    "smoke:localhost": "hardhat run scripts/local-smoke.ts --network localhost",
    "server:local": "bash scripts/server-local-demo.sh",
    "server:local:stop": "bash scripts/stop-server-local-demo.sh",
    "mint:demo:sepolia": "hardhat run scripts/mint-demo-usdc.ts --network sepolia",
    "mint:demo:localhost": "hardhat run scripts/mint-demo-usdc.ts --network localhost",
    "chain": "hardhat node --network hardhat --no-deploy"
  },
  "dependencies": {
    "@fhevm/solidity": "^0.11.1",
    "@openzeppelin/confidential-contracts": "^0.4.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@zama-fhe/oracle-solidity": "^0.1.0",
    "@zama-fhe/relayer-sdk": "^0.4.1",
    "encrypted-types": "^0.0.4",
    "ethers": "^6.16.0",
    "next": "^16.0.7",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.30",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "chai": "^4.5.0",
    "cross-env": "^7.0.3",
    "hardhat": "^2.28.6",
    "hardhat-deploy": "^0.11.45",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "ws@>=7.0.0 <7.5.10": ">=7.5.10",
    "axios@>=1.0.0 <1.8.2": ">=1.8.2",
    "undici@>=6.0.0 <6.21.1": ">=6.21.1 <7.0.0"
  }
}
